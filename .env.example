# Caravanverhuur Spanje — environment variables
# Copy to .env.local for local dev. Production values live in Vercel.
# Never commit real values.

# ───── Public ─────
# Canonical site URL — used for absolute links in emails, OG tags, Stripe redirects.
NEXT_PUBLIC_BASE_URL=https://caravanverhuurspanje.com

# ───── Database (Vercel Postgres) ─────
# Either var works; lib/db.ts prefers POSTGRES_URL, falls back to DATABASE_URL.
POSTGRES_URL=
DATABASE_URL=

# ───── Stripe ─────
# Server-side Stripe key. Use sk_test_... in dev, sk_live_... only in prod.
STRIPE_SECRET_KEY=
# Webhook signing secret from Stripe dashboard (Developers → Webhooks).
# Different value per environment — never reuse test secret in prod.
STRIPE_WEBHOOK_SECRET=

# ───── Holded (pro-forma invoicing) ─────
HOLDED_API_KEY=
# Optional. If unset, signature verification is skipped (only do this in dev).
HOLDED_WEBHOOK_SECRET=

# ───── Email (Resend) ─────
RESEND_API_KEY=
# From-address — must be a verified Resend sender/domain.
EMAIL_FROM=info@caravanverhuurspanje.com

# ───── Auth & secrets ─────
# HMAC key for admin session cookies. Min 32 random bytes. Rotating invalidates all admin sessions.
ADMIN_SECRET=
# Plain admin password fallback (env-based admin login). Prefer DB-backed admin accounts.
STAFF_PASSWORD=
# HMAC key for guest payment links (/betalen/[ref]?token=...). Rotating breaks open payment links.
PAYMENT_LINK_SECRET=
# Bearer token for Vercel Cron jobs. Each cron route checks this header.
CRON_SECRET=
# Token for newsletter unsubscribe links. Rotating breaks existing unsubscribe URLs.
NEWSLETTER_SECRET=
# One-time setup endpoints (initial admin account, schema bootstrap). Set then rotate/remove.
SETUP_SECRET=

# ───── Optional integrations ─────
# Instagram feed widget. Refreshed weekly by /api/cron/refresh-instagram.
INSTAGRAM_ACCESS_TOKEN=
