{
  "ci": {
    "collect": {
      "url": [
        "https://www.caravanverhuurspanje.com",
        "https://www.caravanverhuurspanje.com/caravans",
        "https://www.caravanverhuurspanje.com/bestemmingen",
        "https://www.caravanverhuurspanje.com/boeken",
        "https://www.caravanverhuurspanje.com/contact",
        "https://www.caravanverhuurspanje.com/faq"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.95 }],
        "uses-text-compression": "off",
        "csp-xss": "off",
        "is-crawlable": "off",
        "errors-in-console": "off",
        "unsized-images": "off",
        "image-size-responsive": "off",
        "uses-responsive-images": "off",
        "valid-source-maps": "off"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
